# Required
OPENAI_API_KEY=sk-...

# Optional - override the default model tiers
COMPLEX_MODEL=gpt-5
LIGHT_MODEL=gpt-5-mini
ROUTER_MODEL=gpt-5-nano

# Optional - force a specific tier and skip the router
# FORCE_TIER=complex   # or "light"

# Optional - path to your OAuth client secrets JSON downloaded from Google Cloud Console
# Defaults to ./credentials/oauth_client.json
# GOOGLE_OAUTH_CLIENT_FILE=./credentials/oauth_client.json
